class Solution {
    public int getSecondLargest(int[] arr) {
        int largest=arr[0];
        int secondlargest=-1;
        
        for(int i=1;i<arr.length;i++)
        {
            if(arr[i]>largest)
            {   secondlargest=largest;
                largest=arr[i];
            }
            
            if(secondlargest<arr[i] && arr[i]!=largest)
            {
                secondlargest=arr[i];
            }
           
        }
        return secondlargest;
    }
}
